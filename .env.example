# Copy to .env and fill in.

PORT=3001
HOST=127.0.0.1
# NODE_ENV=production   # set on the server

# --- Login (dashboard auth) ---
STATUS_USER=admin
STATUS_PASS=pick-a-strong-password
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-64-hex-chars

# --- What to watch ---
# systemd units (comma-separated)
STATUS_SERVICES=webmail,nginx,ssh

# TLS certs to check expiry on (fullchain.pem paths, comma-separated)
STATUS_CERTS=/etc/letsencrypt/live/mail.mcnu.ro/fullchain.pem

# HTTP(s) health endpoints to probe (comma-separated)
STATUS_HEALTH_URLS=https://mail.mcnu.ro/api/health

# Filesystem to report disk usage for
STATUS_DISK_PATH=/

# --- Public status page (status.mcnu.ro/status) ---
STATUS_PUBLIC=true
STATUS_PUBLIC_TITLE=MCNU Labs
# Public components (comma-separated; fields |-separated). Public page shows
# ONLY the Label + up/down + uptime — never the target.
#   key|Label|https://url                     (http, legacy)
#   key|Label|http|https://url
#   key|Label|keyword|https://url|ExpectedText (up only if body contains text)
#   key|Label|tls|host[:port][|warnDays]       (cert expiry; warns when <warnDays)
#   key|Label|tcp|host:port                    (port reachable, e.g. SMTP/IMAP/SSH)
#   key|Label|dns|host[|expectedIP]            (resolves, optionally to expectedIP)
STATUS_COMPONENTS=webmail|Webmail|https://mail.mcnu.ro/api/health,site|Website|keyword|https://mcnu.ro|MCNU,mailtls|Mail cert|tls|mail.mcnu.ro,smtp|SMTP|tcp|smtp.purelymail.com:465,dns|DNS|dns|mcnu.ro
STATUS_FAILS_TO_INCIDENT=2
STATUS_PROBE_INTERVAL_MS=60000

# --- Alerting (all optional; a channel activates only when fully configured) ---
# Email (e.g. Purelymail SMTP):
ALERT_SMTP_HOST=smtp.purelymail.com
ALERT_SMTP_PORT=465
ALERT_SMTP_SECURE=true
ALERT_SMTP_USER=andrei@mcnu.ro
ALERT_SMTP_PASS=
ALERT_EMAIL_FROM=andrei@mcnu.ro
ALERT_EMAIL_TO=andrei@mcnu.ro
# SMS via SMSO (smso.ro): only the API key + your number are needed.
# SMSO_SENDER is optional — if omitted, the first approved sender on the account
# is auto-discovered via /api/v1/senders.
SMSO_API_KEY=
SMSO_TO=+40...
# SMSO_SENDER=4   # optional: pin a specific sender id
# Web Push (own VAPID — generate with:
#   node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log('VAPID_PUBLIC='+k.publicKey+'\nVAPID_PRIVATE='+k.privateKey)")
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:andrei@mcnu.ro
